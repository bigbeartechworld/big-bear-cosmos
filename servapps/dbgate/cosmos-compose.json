{
  "cosmos-installer": {
    "routes": [
        {
          "name": "DBGate",
          "description": "Web UI",
          "useHost": true,
          "target": "http://dbgate:3000",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "dbgate": {
  "container_name": "big-bear-dbgate",
  "image": "dbgate/dbgate:7.2.1-alpine@sha256:91ddb068053c8b8cc46f7b5b7e56e5864ac53bcf2a21339fbed6d83e2f97205b",
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-dbgate_config:/root/.dbgate"
  ],
  "ports": [
    "3000:3000"
  ]
}
    }
  }
}
