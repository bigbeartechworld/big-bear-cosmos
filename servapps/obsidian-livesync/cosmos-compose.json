{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Obsidian Livesync",
          "description": "Web UI",
          "useHost": true,
          "target": "http://obsidian-livesync:5984",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "obsidian-livesync": {
  "container_name": "obsidian-livesync",
  "image": "couchdb:3.5.0@sha256:1c0a30a54535377bc9ae23f42efb1ca4e92abe796f78ec98b768ac1d5874cc1b",
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-obsidian-livesync_data_couchdb:/opt/couchdb/data",
    "big-bear-obsidian-livesync_data_local.ini:/opt/couchdb/etc/local.ini"
  ],
  "environment": [
    "COUCHDB_USER=casaos",
    "COUCHDB_PASSWORD=casaos"
  ],
  "ports": [
    "5984:5984"
  ]
}
    }
  }
}
