{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Seerr",
          "description": "Web UI",
          "useHost": true,
          "target": "http://seerr:5056",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "seerr": {
  "image": "seerr/seerr:v3.1.1",
  "init": true,
  "container_name": "big-bear-seerr",
  "ports": [
    "5056:5055"
  ],
  "volumes": [
    "big-bear-seerr_config:/app/config"
  ],
  "environment": [
    "LOG_LEVEL=debug",
    "TZ=$TZ"
  ],
  "healthcheck": {
    "test": "wget --no-verbose --tries=1 --spider http://localhost:5055/api/v1/settings/public || exit 1",
    "interval": "30s",
    "timeout": "10s",
    "retries": 3,
    "start_period": "20s"
  },
  "restart": "unless-stopped",
  "network_mode": "bridge"
}
    }
  }
}
