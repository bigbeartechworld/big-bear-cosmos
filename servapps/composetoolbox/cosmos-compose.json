{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Compose Toolbox",
          "description": "Web UI",
          "useHost": true,
          "target": "http://composetoolbox:3002",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "composetoolbox": {
  "environment": {
    "NODE_ENV": "production"
  },
  "image": "ghcr.io/bluegoosemedia/composetoolbox:latest@sha256:61e8a6f0a00583f145e83018ce0954089f5bd89157dc39ef7459043643ca17f6",
  "pull_policy": "always",
  "ports": [
    "3002:3000"
  ],
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-composetoolbox_data:/app/data"
  ],
  "container_name": "big-bear-composetoolbox"
}
    }
  }
}
