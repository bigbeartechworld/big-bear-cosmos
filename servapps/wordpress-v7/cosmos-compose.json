{
  "cosmos-installer": {
    "routes": [
        {
          "name": "WordPress v7",
          "description": "Web UI",
          "useHost": true,
          "target": "http://wordpress-v7:8084",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "wordpress-v7": {
  "image": "wordpress:7.0.1",
  "ports": [
    "8084:80"
  ],
  "environment": {
    "WORDPRESS_DB_HOST": "db",
    "WORDPRESS_DB_USER": "casaos",
    "WORDPRESS_DB_PASSWORD": "casaos",
    "WORDPRESS_DB_NAME": "wordpress"
  },
  "volumes": [
    "big-bear-wordpress-v7_html:/var/www/html"
  ],
  "depends_on": [
    "db"
  ]
}
    }
  }
}
