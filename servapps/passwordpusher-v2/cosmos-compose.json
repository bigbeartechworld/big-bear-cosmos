{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Password Pusher v2",
          "description": "Web UI",
          "useHost": true,
          "target": "http://passwordpusher-v2:5101",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "passwordpusher-v2": {
  "container_name": "big-bear-pwpush-v2",
  "image": "pglombardo/pwpush:2.4.3",
  "restart": "unless-stopped",
  "environment": {
    "DATABASE_URL": "postgresql://pwpusher:6280144a-56af-486f-9088-ac7301399328@big-bear-pwpush-v2-db:5432/passwordpusher_db",
    "PWP__PW__EXPIRE_AFTER_DAYS_DEFAULT": "1",
    "PWP__PW__EXPIRE_AFTER_VIEWS_MIN": "1",
    "PWP__PW__RETRIEVAL_STEP_DEFAULT": "true"
  },
  "volumes": [
    "big-bear-passwordpusher-v2_storage:/opt/PasswordPusher/storage:rw"
  ],
  "ports": [
    "5101:5100"
  ],
  "networks": [
    "big_bear_pwpush_v2_network"
  ],
  "depends_on": {
    "big-bear-pwpush-v2-db": {
      "condition": "service_healthy"
    }
  }
}
    }
  }
}
