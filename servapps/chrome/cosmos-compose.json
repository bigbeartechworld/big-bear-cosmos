{
  "cosmos-installer": {
    "routes": [
        {
          "name": "chrome",
          "description": "Web UI",
          "useHost": true,
          "target": "http://chrome:6902",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "chrome": {
  "container_name": "big-bear-chrome",
  "image": "kasmweb/chrome:1.15.0-rolling@sha256:ae404814331aa0259bfc71cfb3a07e5aca4b147595b833c0552288305f273e1a",
  "ports": [
    "6902:6901"
  ],
  "environment": [
    "VNC_PW=casaos",
    "LAUNCH_URL=https://community.bigbeartechworld.com/"
  ],
  "shm_size": "512m",
  "volumes": [
    "big-bear-chrome_Downloads:/home/kasm-user/Downloads"
  ]
}
    }
  }
}
