{
  "cosmos-installer": {
    "routes": [
        {
          "name": "FarmOS v4",
          "description": "Web UI",
          "useHost": true,
          "target": "http://farmos-v4:8083",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "farmos-v4": {
  "container_name": "big-bear-farmos-v4",
  "image": "farmos/farmos:4.0.0",
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-farmos-v4_sites:/opt/drupal/web/sites"
  ],
  "ports": [
    "8083:80"
  ],
  "depends_on": [
    "big-bear-farmos-v4-db"
  ],
  "networks": [
    "big-bear-farmos-v4-network"
  ]
}
    }
  }
}
