{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Nexterm",
          "description": "Web UI",
          "useHost": true,
          "target": "http://nexterm:6989",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "nexterm": {
  "container_name": "big-bear-nexterm",
  "image": "nexterm/aio:1.2.1-BETA@sha256:9760eaa844e679e595e1ca53ef667fa5e478e1bb2cc9a7b862aa446dc692385e",
  "restart": "unless-stopped",
  "environment": [
    "ENCRYPTION_KEY="
  ],
  "volumes": [
    "big-bear-nexterm_data:/app/data"
  ],
  "ports": [
    "6989:6989"
  ]
}
    }
  }
}
