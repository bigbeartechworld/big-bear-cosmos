{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Nexterm",
          "description": "Web UI",
          "useHost": true,
          "target": "http://nexterm:6989",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "nexterm": {
  "container_name": "big-bear-nexterm",
  "image": "nexterm/aio:1.2.2-BETA@sha256:def6f6a50b48c842d3fbe796ff8e7ce6b8fa54e2d92116a62742859c64f47d7e",
  "restart": "unless-stopped",
  "environment": [
    "ENCRYPTION_KEY="
  ],
  "volumes": [
    "big-bear-nexterm_data:/app/data"
  ],
  "ports": [
    "6989:6989"
  ]
}
    }
  }
}
