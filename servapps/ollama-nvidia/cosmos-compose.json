{
  "cosmos-installer": {
    "routes": [
        {
          "name": "Ollama - NVIDIA",
          "description": "Web UI",
          "useHost": true,
          "target": "http://ollama-nvidia:11434",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "ollama-nvidia": {
  "container_name": "big-bear-ollama-nvidia",
  "image": "ollama/ollama:0.32.1@sha256:6345fbc18bd73a1e16404be681dbc6fd291a027cab43ed541abe78c4c81051b0",
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-ollama-nvidia_.ollama:/root/.ollama"
  ],
  "ports": [
    "11434:11434"
  ],
  "deploy": {
    "resources": {
      "reservations": {
        "devices": [
          {
            "driver": "nvidia",
            "count": "all",
            "capabilities": [
              "gpu"
            ]
          }
        ]
      }
    }
  }
}
    }
  }
}
