{
  "cosmos-installer": {
    "routes": [
        {
          "name": "RackPeek",
          "description": "Web UI",
          "useHost": true,
          "target": "http://rackpeek:8095",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "BlockAPIAbuse": true
        }
      ],
    "services": {
      "rackpeek": {
  "container_name": "big-bear-rackpeek",
  "image": "aptacode/rackpeek:v2.0.0",
  "restart": "unless-stopped",
  "volumes": [
    "big-bear-rackpeek_config:/app/config"
  ],
  "ports": [
    "8095:8080"
  ]
}
    }
  }
}
